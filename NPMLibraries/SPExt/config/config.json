{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "sp-ext-application-customizer": {
      "components": [
        {
          "entrypoint": "./lib/extensions/spExt/SpExtApplicationCustomizer.js",
          "manifest": "./src/extensions/spExt/SpExtApplicationCustomizer.manifest.json"
        }
      ]
    }
  },
  "externals": {
    "@juliemturner/lib1": {
      "path": "https://localhost:3010/lib1.js",
      "globalName": "lib1",
      "globalDependencies": ["@juliemturner/lib1_1"]
    },
    "@juliemturner/lib1_1": {
      "path": "https://localhost:3000/lib1_1.js",
      "globalName": "lib11"
    }
  },
  "localizedResources": {
    "SpExtApplicationCustomizerStrings": "lib/extensions/spExt/loc/{locale}.js"
  }
}
